# ── Base de datos ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/servicios_profesionales
REDIS_URL=redis://localhost:6379

# ── Auth (NextAuth.js) ─────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Mercado Pago ───────────────────────────────────────────────────────────────
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=
MP_PUBLIC_KEY=       # solo para el frontend (NEXT_PUBLIC_)
NEXT_PUBLIC_MP_PUBLIC_KEY=

# ── WhatsApp (Meta Cloud API) ──────────────────────────────────────────────────
WA_PHONE_NUMBER_ID=
WA_ACCESS_TOKEN=
WA_VERIFY_TOKEN=generate-a-random-string

# ── Email (Resend) ─────────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=noreply@tudominio.com

# ── Analytics (solo frontend) ─────────────────────────────────────────────────
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
NEXT_PUBLIC_META_PIXEL_ID=

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000
PLATFORM_FEE_PERCENT=15    # comisión de la plataforma (%)
CBU_ALIAS=tudominio.mp
CBU_NUMBER=0000000000000000000000
