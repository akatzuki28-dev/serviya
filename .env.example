# ── Base de datos ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/servicios_profesionales
REDIS_URL=redis://localhost:6379

# ── Auth (NextAuth.js) ─────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Pasarela de pago ───────────────────────────────────────────────────────────
# Proveedor activo para cobros online: "mobbex" (default) | "mp"
PAYMENT_PROVIDER=mobbex

# ── Mercado Pago (solo si PAYMENT_PROVIDER=mp) ──────────────────────────────────
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=
MP_PUBLIC_KEY=       # solo para el frontend (NEXT_PUBLIC_)
NEXT_PUBLIC_MP_PUBLIC_KEY=

# ── Mobbex (PAYMENT_PROVIDER=mobbex) ────────────────────────────────────────────
MOBBEX_API_KEY=            # x-api-key de la aplicación (panel dev de Mobbex)
MOBBEX_ACCESS_TOKEN=       # x-access-token de la entidad/comercio
MOBBEX_WEBHOOK_SECRET=     # secreto compartido que viaja en ?secret= del webhook
MOBBEX_TEST=false          # "true" para usar tarjetas de prueba

# ── WhatsApp (Meta Cloud API) ──────────────────────────────────────────────────
WA_PHONE_NUMBER_ID=
WA_ACCESS_TOKEN=
WA_VERIFY_TOKEN=generate-a-random-string

# ── Email (Resend) ─────────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=noreply@tudominio.com

# ── Analytics (solo frontend) ─────────────────────────────────────────────────
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
NEXT_PUBLIC_META_PIXEL_ID=

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000
PLATFORM_FEE_PERCENT=15    # comisión de la plataforma (%)
CBU_ALIAS=tudominio.mp
CBU_NUMBER=0000000000000000000000
